source "https://rubygems.org"

# Modern Jekyll 4 for local development and (via GitHub Actions) deployment.
# The site uses a hand-built theme/layout, so no theme gem is required.
gem "jekyll", "~> 4.3"

# Local development server
gem "webrick"

# Gems removed from Ruby's default set (Ruby 3.4+/4.0) that Jekyll still requires
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
